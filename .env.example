# LLM providers (AUTOLOGGER_ prefix — used by providers.py)
AUTOLOGGER_ANTHROPIC_API_KEY=
AUTOLOGGER_OPENAI_API_KEY=
AUTOLOGGER_GEMINI_API_KEY=
AUTOLOGGER_OLLAMA_BASE_URL=http://localhost:11434
AUTOLOGGER_WHISPER_DEVICE=auto

# AutoRAG settings
AUTORAG_DB_PATH=~/.autorag/autorag.db
AUTORAG_MODEL=claude-sonnet-4-6
