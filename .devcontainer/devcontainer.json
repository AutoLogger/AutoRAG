{
  "name": "Claude Code Sandbox",
  "build": {
    "dockerfile": "Dockerfile",
    "args": {
      "TZ": "${localEnv:TZ:America/Los_Angeles}",
      "CLAUDE_CODE_VERSION": "latest",
      "GIT_DELTA_VERSION": "0.18.2"
    }
  },
  "features": {
    "ghcr.io/devcontainers/features/nvidia-cuda:3.0.0": {
      // "installToolkit": true,
      "cudaVersion": "13.0"
    }
  },
  "hostRequirements": {
    "gpu": "optional"
  },
  "runArgs": [
    "--cap-add=NET_ADMIN",
    "--cap-add=NET_RAW",
    "--add-host=host.docker.internal:host-gateway",
    "--gpus=all"
  ],
  "customizations": {
    "vscode": {
      "extensions": [
        "ms-python.python",
        "charliermarsh.ruff",
        "anthropic.claude-code"
      ],
      "settings": {
        "terminal.integrated.defaultProfile.linux": "bash"
      }
    }
  },
  "remoteUser": "node",
  "mounts": [
    "source=claude-code-bashhistory-${devcontainerId},target=/commandhistory,type=volume",
    "source=claude-code-config-${devcontainerId},target=/home/node/.claude,type=volume",
    "source=autologger-${devcontainerId},target=/home/.autologger,type=volume"
    // "source=puppeteer-${devcontainerId}, target=/home/node/.cache/puppeteer,type=volume"
  ],
  "containerEnv": {
    // "ANTHROPIC_BASE_URL": "http://host.docker.internal:11434",
    // "ANTHROPIC_AUTH_TOKEN": "ollama",
    // "ANTHROPIC_API_KEY": "",
    // "ANTHROPIC_DEFAULT_OPUS_MODEL": "qwen3.5:9b-claude",
    // "ANTHROPIC_DEFAULT_SONNET_MODEL": "qwen3.5:9b-claude",
    // "ANTHROPIC_DEFAULT_HAIKU_MODEL": "qwen3.5:9b-claude",
    // "CLAUDE_CODE_SUBAGENT_MODEL": "qwen3.5:9b-claude",
    // "ANTHROPIC_MODEL": "qwen3.5:9b-claude",
    // "NODE_OPTIONS": "--max-old-space-size=4096",
    "CLAUDE_CONFIG_DIR": "/home/node/.claude",
    "SEARXNG_URL": "http://host.docker.internal:80",
    "NVIDIA_VISIBLE_DEVICES": "all",
    "NVIDIA_DRIVER_CAPABILITIES": "compute,utility",
    "AUTORAG_OLLAMA_BASE_URL": "http://host.docker.internal:11434"
  },
  "workspaceMount": "source=${localWorkspaceFolder},target=/workspace,type=bind,consistency=delegated",
  "workspaceFolder": "/workspace",
  // "postStartCommand": "sudo /usr/local/bin/init-firewall.sh",
  "waitFor": "postStartCommand"
}