{
  "name": "Claude Code Sandbox",
  "build": {
    "dockerfile": "Dockerfile",
    "args": {
      "TZ": "${localEnv:TZ:America/Los_Angeles}",
      "CLAUDE_CODE_VERSION": "latest",
      "GIT_DELTA_VERSION": "0.18.2",
      "OLLAMA_VERSION": "0.24.0"
    }
  },
  "hostRequirements": {
    "gpu": "optional"
  },
  "runArgs": [
    "--cap-add=NET_ADMIN",
    "--cap-add=NET_RAW",
    "--cap-add=SYS_ADMIN",
    "--add-host=host.docker.internal:host-gateway",
    "--gpus=all"
  ],
  "customizations": {
    "vscode": {
      "extensions": [
        "ms-python.python",
        "charliermarsh.ruff",
        "anthropic.claude-code"
      ],
      "settings": {
        "terminal.integrated.defaultProfile.linux": "bash"
      }
    }
  },
  "remoteUser": "node",
  "mounts": [
    "source=claude-code-bashhistory-${devcontainerId},target=/commandhistory,type=volume",
    "source=claude-code,target=/home/node/.claude,type=volume",
    "source=autorag-${devcontainerId},target=/home/node/.autorag,type=volume",
    "source=uv-cache,target=/home/node/.cache/uv,type=volume",
    "source=npm-cache,target=/home/node/.npm,type=volume",
    "source=chrome-config,target=/home/node/.config/google-chrome,type=volume",
    "source=chrome-policies,target=/etc/opt/chrome/policies,type=volume",
    "source=matplotlib,target=/home/node/.config/matplotlib,type=volume",
    "source=local-share,target=/home/node/.local/share,type=volume",
    "source=/run/user/1000/wayland-0,target=/run/user/1000/wayland-0,type=bind",
    "source=/run/user/1000/pulse,target=/run/user/1000/pulse,type=bind",
    // Native in-container Ollama: share the host's model store so pulls
    // persist across rebuilds and are reused from/by a host Ollama.
    "source=${localEnv:HOME}/.ollama,target=/home/node/.ollama,type=bind"
  ],
  "containerEnv": {
    "XDG_RUNTIME_DIR": "/run/user/1000",
    "PULSE_SERVER": "unix:/run/user/1000/pulse/native",
    "WAYLAND_DISPLAY": "wayland-0",
    "ELECTRON_OZONE_PLATFORM_HINT": "wayland",
    "CLAUDE_CONFIG_DIR": "/home/node/.claude",
    "SEARXNG_URL": "http://host.docker.internal:80",
    "NVIDIA_VISIBLE_DEVICES": "all",
    "NVIDIA_DRIVER_CAPABILITIES": "compute,utility,graphics,video",
    "AUTORAG_OLLAMA_BASE_URL": "http://localhost:11434",
    "HF_TOKEN": "${localEnv:HF_TOKEN}",
    "UV_LINK_MODE": "copy",
    "MPLCONFIGDIR": "/home/node/.config/matplotlib"
  },
  "workspaceMount": "source=${localWorkspaceFolder},target=/workspace/autorag,type=bind,consistency=delegated",
  "workspaceFolder": "/workspace/autorag",
  // Parallel named commands (run as remoteUser `node` — no sudo): bring up the
  // native Ollama server and sync the workspace venv independently.
  "postStartCommand": {
    "ollama": "/usr/local/bin/start-ollama",
    "workspace": "cd /workspace/autorag && uv sync --all-extras && rm -f /home/node/.config/google-chrome/SingletonLock /home/node/.config/google-chrome/SingletonCookie /home/node/.config/google-chrome/SingletonSocket"
  },
  // "postStartCommand": "sudo /usr/local/bin/init-firewall.sh",
  "waitFor": "postStartCommand"
}